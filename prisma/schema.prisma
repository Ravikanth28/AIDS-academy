generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  email     String?  @unique
  password  String?
  role      Role     @default(STUDENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  otpSessions      OTPSession[]
  enrollments      Enrollment[]
  testAttempts     TestAttempt[]
  certificates     Certificate[]
  activityLogs     ActivityLog[]
  monthlyPoints    MonthlyPoints[]
  practiceAttempts PracticeAttempt[]
  codingAttempts   CodingAttempt[]
  codingDrafts     CodingDraft[]
  courseAssignments CourseAssignment[]
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  detail    String?  @db.Text
  points    Int      @default(0)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model MonthlyPoints {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month     Int      // 1-12
  year      Int
  points    Int      @default(0)
  rank      Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, month, year])
  @@index([month, year])
}

enum Role {
  ADMIN
  STUDENT
}

model OTPSession {
  id        String   @id @default(cuid())
  phone     String
  otp       String
  expiresAt DateTime
  used      Boolean  @default(false)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([phone])
}

model Course {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  thumbnail   String?  @db.LongText
  category    String?  @default("AI & Data Science")
  isPublished    Boolean  @default(false)
  isAssignedOnly Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt   DateTime @updatedAt

  modules      Module[]
  enrollments  Enrollment[]
  certificates Certificate[]
  assignments  CourseAssignment[]
}

model CourseAssignment {
  id        String   @id @default(cuid())
  courseId  String
  userId    String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([courseId, userId])
  @@index([courseId])
  @@index([userId])
}

model Module {
  id            String   @id @default(cuid())
  title         String
  description   String?  @db.Text
  order         Int
  courseId      String
  course        Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  passingScore  Float    @default(60)
  questionCount Int      @default(10)
  createdAt     DateTime @default(now())

  videos           Video[]
  questions        Question[]
  testAttempts     TestAttempt[]
  moduleProgress   ModuleProgress[]
  practiceAttempts PracticeAttempt[]
  codingAttempts   CodingAttempt[]
  codingQuestions  CodingQuestion[]
  codingDrafts     CodingDraft[]

  @@index([courseId])
}

model Video {
  id          String   @id @default(cuid())
  title       String
  youtubeUrl  String
  description String?  @db.Text
  order       Int      @default(0)
  moduleId    String
  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  checkpointQuestions Question[]

  @@index([moduleId])
}

model Question {
  id          String   @id @default(cuid())
  text        String   @db.Text
  moduleId    String
  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  explanation String?  @db.Text
  videoId     String?
  video       Video?   @relation(fields: [videoId], references: [id], onDelete: SetNull)
  timestamp   Int?     // seconds into the video for checkpoint questions
  createdAt   DateTime @default(now())

  options     QuestionOption[]
  testAnswers TestAnswer[]

  @@index([moduleId])
  @@index([videoId])
}

model QuestionOption {
  id         String   @id @default(cuid())
  text       String   @db.Text
  isCorrect  Boolean  @default(false)
  order      Int      @default(0)
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model Enrollment {
  id         String   @id @default(cuid())
  userId     String
  courseId   String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrolledAt DateTime @default(now())

  moduleProgress ModuleProgress[]

  @@unique([userId, courseId])
  @@index([courseId])
}

model ModuleProgress {
  id             String     @id @default(cuid())
  enrollmentId   String
  moduleId       String
  enrollment     Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  module         Module     @relation(fields: [moduleId], references: [id])
  // Stored as JSON string — auto-parsed to string[] by Prisma extension in lib/prisma.ts
  videosWatched  String    @default("[]") @db.VarChar(4000)
  videoCompleted Boolean    @default(false)
  testPassed     Boolean    @default(false)
  testScore      Float?
  completedAt    DateTime?

  @@unique([enrollmentId, moduleId])
  @@index([moduleId])
}

model TestAttempt {
  id             String   @id @default(cuid())
  userId         String
  moduleId       String
  user           User     @relation(fields: [userId], references: [id])
  module         Module   @relation(fields: [moduleId], references: [id])
  score          Float
  totalQuestions Int
  correctAnswers Int
  passed         Boolean
  createdAt      DateTime @default(now())

  answers TestAnswer[]

  @@index([userId])
  @@index([moduleId])
}

model TestAnswer {
  id               String      @id @default(cuid())
  testAttemptId    String
  questionId       String
  selectedOptionId String?
  isCorrect        Boolean
  testAttempt      TestAttempt @relation(fields: [testAttemptId], references: [id], onDelete: Cascade)
  question         Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([testAttemptId])
  @@index([questionId])
}

enum CertificateStatus {
  PENDING
  VERIFIED
  REVOKED
}

model Certificate {
  id            String            @id @default(cuid())
  userId        String
  courseId      String
  certificateNo String            @unique
  status        CertificateStatus @default(PENDING)
  revokedReason String?           @db.Text
  user          User              @relation(fields: [userId], references: [id])
  course        Course            @relation(fields: [courseId], references: [id])
  issuedAt      DateTime          @default(now())

  @@unique([userId, courseId])
  @@index([courseId])
}

model PracticeAttempt {
  id                 String   @id @default(cuid())
  userId             String
  moduleId           String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  module             Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  mcqScore           Float    @default(0)
  totalMcq           Int      @default(0)
  correctMcq         Int      @default(0)
  exercisesCompleted Int      @default(0)
  totalExercises     Int      @default(0)
  overallScore       Float    @default(0)
  completedAt        DateTime @default(now())

  @@index([userId])
  @@index([moduleId])
}

model CodingAttempt {
  id            String   @id @default(cuid())
  userId        String
  moduleId      String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  module        Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  score         Float    @default(0)
  totalProblems Int      @default(0)
  passed        Boolean  @default(false)
  feedback      String?  @db.Text
  completedAt   DateTime @default(now())

  @@index([userId])
  @@index([moduleId])
}

model CodingDraft {
  id        String   @id @default(cuid())
  userId    String
  moduleId  String
  solutions String   @db.LongText
  languages String   @db.VarChar(2000) @default("{}")
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
  @@index([userId])
  @@index([moduleId])
}

model CodingQuestion {
  id            String   @id @default(cuid())
  moduleId      String
  module        Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  type          String   @default("coding")       // "coding" | "sql"
  difficulty    String   @default("medium")       // "easy" | "medium" | "hard"
  mode          String   @default("both")         // "practice" | "test" | "both"
  title          String
  description    String   @db.Text
  examples       String   @db.VarChar(5000) @default("[]")
  constraints    String?  @db.Text
  starterCode    String   @db.VarChar(10000) @default("")
  hints          String   @db.VarChar(3000) @default("[]")
  sampleSolution String   @db.LongText
  order         Int      @default(0)
  createdAt     DateTime @default(now())

  @@index([moduleId])
}
